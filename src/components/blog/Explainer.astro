---
interface Props {
  term?: string;
  title?: string;
}
const { term, title } = Astro.props;
const heading = title ?? (term ? `מה זה ${term}?` : 'הסבר נוסף');
---

<details class="explainer">
  <summary class="explainer-summary" dir="auto">
    <span class="explainer-icon" aria-hidden="true">?</span>
    <span class="explainer-title">{heading}</span>
    <span class="explainer-chevron" aria-hidden="true">
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
        <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </summary>
  <div class="explainer-body" dir="auto"><slot /></div>
</details>

<style>
  .explainer {
    border: 1px solid color-mix(in oklch, var(--color-accent-2) 28%, transparent);
    background: color-mix(in oklch, var(--color-accent-2) 5%, transparent);
    border-radius: 10px;
    margin: 1.4em 0;
    overflow: hidden;
    transition: border-color 150ms ease, background 150ms ease;
  }
  .explainer:hover {
    border-color: color-mix(in oklch, var(--color-accent-2) 45%, transparent);
  }
  .explainer-summary {
    list-style: none;
    cursor: pointer;
    user-select: none;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.7rem 0.95rem;
    color: var(--color-accent-2);
    font-weight: 600;
    font-size: 0.95em;
    line-height: 1.4;
  }
  .explainer-summary::-webkit-details-marker { display: none; }
  .explainer-summary::marker { content: ''; }
  .explainer-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--color-accent-2);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    flex-shrink: 0;
  }
  .explainer-title {
    flex: 1;
    min-width: 0;
  }
  .explainer-chevron {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 200ms cubic-bezier(0.34, 1.56, 0.64, 1);
    color: color-mix(in oklch, var(--color-accent-2) 80%, transparent);
    flex-shrink: 0;
  }
  .explainer[open] .explainer-chevron {
    transform: rotate(180deg);
  }
  .explainer-body {
    padding: 0.9rem 0.95rem 0.95rem;
    border-top: 1px solid color-mix(in oklch, var(--color-accent-2) 18%, transparent);
    color: var(--color-ink);
    line-height: 1.7;
    font-weight: 400;
  }
  .explainer-body :global(p) {
    margin-block: 0.55em;
  }
  .explainer-body :global(p:first-child) {
    margin-block-start: 0;
  }
  .explainer-body :global(p:last-child) {
    margin-block-end: 0;
  }
</style>
