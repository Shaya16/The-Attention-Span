---
type Type = 'info' | 'warning' | 'note' | 'tip';

interface Props {
  type?: Type;
  title?: string;
}

const { type = 'info', title } = Astro.props;

const PRESETS: Record<Type, { color: string; label: string; icon: string }> = {
  info:    { color: '#3b82f6', label: 'מידע',  icon: 'i' },
  warning: { color: '#f59e0b', label: 'אזהרה', icon: '!' },
  note:    { color: '#8b5cf6', label: 'הערה',  icon: '✎' },
  tip:     { color: '#10b981', label: 'טיפ',   icon: '★' },
};
const p = PRESETS[type];
---

<aside class={`callout callout-${type}`} style={`--c:${p.color}`}>
  <div class="callout-head">
    <span class="callout-icon" aria-hidden="true">{p.icon}</span>
    <span class="callout-label">{title ?? p.label}</span>
  </div>
  <div class="callout-body" dir="auto"><slot /></div>
</aside>

<style>
  .callout {
    border-inline-start: 4px solid var(--c);
    background: color-mix(in oklch, var(--c) 8%, transparent);
    border-radius: 6px;
    padding: 14px 18px;
    margin: 1.4em 0;
  }
  .callout-head {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--c);
    font-weight: 600;
    margin-bottom: 6px;
    font-size: 0.92em;
  }
  .callout-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--c);
    color: #fff;
    font-family: ui-monospace, monospace;
    font-size: 12px;
    font-weight: 700;
  }
  .callout-body :global(p) {
    margin-block: 0.4em;
  }
  .callout-body :global(p:first-child) {
    margin-block-start: 0;
  }
  .callout-body :global(p:last-child) {
    margin-block-end: 0;
  }
</style>
