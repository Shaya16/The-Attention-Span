---
import BaseLayout from './BaseLayout.astro';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { SITE } from '../lib/site';

interface Props {
  post: CollectionEntry<'blog'>;
  readingTime?: string;
}

const { post, readingTime } = Astro.props;
const { title, description, pubDate, updatedDate, tags, image } = post.data;

const dateStr = pubDate.toLocaleDateString('he-IL', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const ogImage = image
  ? {
      src: image.src.src,
      alt: image.alt,
      width: image.src.width,
      height: image.src.height,
    }
  : undefined;

const canonicalPostUrl = new URL(`/posts/${post.id}/`, SITE.url).href;
---

<BaseLayout
  title={title}
  description={description}
  image={ogImage}
  type="article"
  pubDate={pubDate}
  updatedDate={updatedDate}
  tags={tags}
>
  <link
    rel="stylesheet"
    href="https://unpkg.com/applause-button/dist/applause-button.css"
  />

  <article class="prose-post" dir="rtl" lang="he">
    <h1 dir="auto">{title}</h1>
    <p class="post-subtitle !mb-4" dir="rtl">{description}</p>

    <div class="mb-5 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-[var(--color-muted)]">
      {readingTime && <span>{readingTime}</span>}
      {readingTime && <span aria-hidden="true">·</span>}
      <time datetime={pubDate.toISOString()}>{dateStr}</time>
      {tags.length > 0 && (
        <>
          <span aria-hidden="true">·</span>
          <ul class="flex flex-wrap gap-1.5" dir="ltr">
            {tags.map((tag) => (
              <li class="rounded-full bg-[color-mix(in_oklch,var(--color-accent-2)_15%,transparent)] px-2 py-0.5 text-xs">
                #{tag}
              </li>
            ))}
          </ul>
        </>
      )}
    </div>

    <div class="mb-10 flex items-center gap-3">
      <div
        aria-hidden="true"
        class="flex h-10 w-10 items-center justify-center rounded-full text-base font-semibold text-[var(--color-paper)]"
        style="background: linear-gradient(135deg, var(--color-accent), var(--color-accent-2));"
      >
        ש
      </div>
      <span class="text-sm font-medium text-[var(--color-ink)]">שי אביבי</span>
    </div>

    {image ? (
      <figure class="post-cover">
        <Image src={image.src} alt={image.alt} />
      </figure>
    ) : (
      <div class="post-cover post-cover--placeholder" aria-hidden="true"></div>
    )}

    <slot />
  </article>

  <div class="prose-post mt-16 mb-10 flex flex-col items-center gap-2 border-t border-[var(--color-line)] pt-10">
    <applause-button
      url={canonicalPostUrl}
      color="oklch(0.65 0.22 25)"
      multiclap="true"
      style="width: 58px; height: 58px;"
    ></applause-button>
    <span class="text-xs text-[var(--color-muted)]">אהבתם? לחצו כפיים</span>
  </div>

  <script
    src="https://unpkg.com/applause-button/dist/applause-button.js"
    is:inline
    defer
  ></script>
</BaseLayout>
