---
import '../styles/global.css';
import { SITE } from '../lib/site';

interface Props {
  title?: string;
  description?: string;
  image?: { src: string; alt?: string; width?: number; height?: number };
  type?: 'website' | 'article';
  pubDate?: Date;
  updatedDate?: Date;
  tags?: string[];
  theme?: 'light' | 'dark';
  lang?: string;
  dir?: 'rtl' | 'ltr';
  noindex?: boolean;
  appendSiteName?: boolean;
  mainClass?: string;
}

const {
  title,
  description = SITE.defaultDescription,
  image,
  type = 'website',
  pubDate,
  updatedDate,
  tags = [],
  theme = 'light',
  lang = 'he',
  dir = 'rtl',
  noindex = false,
  appendSiteName = true,
  mainClass = 'max-w-4xl',
} = Astro.props;

const pageTitle = title ?? SITE.name;
const fullTitle =
  title && appendSiteName && title !== SITE.name
    ? `${title} · ${SITE.name}`
    : pageTitle;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;

const ogImagePath = image?.src ?? SITE.defaultOgImage;
const ogImageUrl = new URL(ogImagePath, Astro.site).href;
const ogImageAlt =
  image?.alt ??
  `${SITE.name} - interactive explainers on machine learning and deep learning`;
const ogLocale = lang.startsWith('he') ? SITE.locale : SITE.alternateLocale;
const themeColorValue =
  theme === 'dark' ? SITE.themeColor.dark : SITE.themeColor.light;

const jsonLd =
  type === 'article' && pubDate
    ? {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description,
        image: ogImageUrl,
        url: canonicalUrl,
        datePublished: pubDate.toISOString(),
        dateModified: (updatedDate ?? pubDate).toISOString(),
        inLanguage: lang,
        keywords: tags.join(', '),
        author: {
          '@type': 'Person',
          name: SITE.author.name,
          url: SITE.author.githubUrl,
        },
        publisher: {
          '@type': 'Organization',
          name: SITE.name,
          logo: {
            '@type': 'ImageObject',
            url: new URL('/favicon.svg', Astro.site).href,
          },
        },
        mainEntityOfPage: {
          '@type': 'WebPage',
          '@id': canonicalUrl,
        },
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: SITE.name,
        url: SITE.url,
        description,
        inLanguage: lang,
        author: {
          '@type': 'Person',
          name: SITE.author.name,
          url: SITE.author.githubUrl,
        },
      };
---

<!doctype html>
<html lang={lang} dir={dir} data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={SITE.author.name} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content={themeColorValue} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.name} RSS`} href="/rss.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Assistant:wght@200;300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700;800&family=Geist+Mono:wght@400;500&display=swap"
    />

    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:title" content={title ?? SITE.name} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    {image?.width && <meta property="og:image:width" content={String(image.width)} />}
    {image?.height && <meta property="og:image:height" content={String(image.height)} />}
    {type === 'article' && pubDate && (
      <meta property="article:published_time" content={pubDate.toISOString()} />
    )}
    {type === 'article' && updatedDate && (
      <meta property="article:modified_time" content={updatedDate.toISOString()} />
    )}
    {type === 'article' && (
      <meta property="article:author" content={SITE.author.name} />
    )}
    {type === 'article' && tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title ?? SITE.name} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  </head>
  <body>
    <header class="sticky top-0 z-50 border-b border-[var(--color-line)] bg-[color-mix(in_oklch,var(--color-paper)_75%,transparent)] backdrop-blur-md">
      <div class="mx-auto flex max-w-[90rem] flex-wrap items-center justify-between gap-x-5 gap-y-3 px-4 py-2.5 sm:px-6 sm:py-3">
        <a href="/" class="logo flex items-center gap-3" aria-label="The Attention Span - home">
          <svg
            width="34"
            height="34"
            viewBox="0 0 60 60"
            aria-hidden="true"
            class="block"
          >
            <circle cx="10" cy="10" r="3" fill="var(--color-ink)" />
            <circle cx="30" cy="10" r="5" fill="var(--color-ink)" />
            <circle cx="50" cy="10" r="5" fill="var(--color-accent)" class="logo-dot logo-dot-red" />
            <circle cx="10" cy="30" r="5" fill="var(--color-accent-4)" class="logo-dot logo-dot-yellow" />
            <circle cx="30" cy="30" r="5" fill="var(--color-ink)" />
            <circle cx="50" cy="30" r="5" fill="var(--color-ink)" />
            <circle cx="10" cy="50" r="3" fill="var(--color-accent-2)" class="logo-dot logo-dot-blue" />
            <circle cx="30" cy="50" r="5" fill="var(--color-ink)" />
            <circle cx="50" cy="50" r="4" fill="var(--color-accent-3)" class="logo-dot logo-dot-green" />
          </svg>
          <span class="hidden text-base font-semibold tracking-tight text-[var(--color-ink)] sm:inline">
            The Attention Span
          </span>
        </a>
        <nav class="flex items-center gap-4 text-sm text-[var(--color-muted)] sm:gap-5">
          <a
            href="/about"
            class="hover:text-[var(--color-ink)] transition"
          >
            אודות
          </a>
          <a
            href="/rss.xml"
            aria-label="RSS"
            class="transition hover:opacity-70"
            style="color: #F26522;"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20A2.18 2.18 0 0 1 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z" />
            </svg>
          </a>
          <a
            href="https://github.com/Shaya16"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="transition hover:opacity-70"
            style="color: var(--gh-icon);"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.373 0 12c0 5.303 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.725-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.31.468-2.381 1.235-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.3 1.23A11.5 11.5 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.29-1.552 3.296-1.23 3.296-1.23.653 1.652.242 2.873.119 3.176.77.84 1.234 1.911 1.234 3.221 0 4.609-2.806 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .321.218.694.825.576C20.565 21.796 24 17.298 24 12c0-6.627-5.373-12-12-12z" />
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/shayavivi/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="transition hover:opacity-70"
            style="color: #0A66C2;"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.063 2.063 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
        </nav>
      </div>
    </header>

    <div class="mx-auto mt-6 max-w-[90rem] px-4 sm:px-6">
      <slot name="hero" />
    </div>

    <div class="mx-auto max-w-[90rem] px-4 sm:px-6">
      <slot name="wide" />
    </div>

    <div class={`mx-auto ${mainClass} px-5 py-8 sm:px-6 sm:py-12`}>
      <main>
        <slot />
      </main>

      <footer class="mt-24 border-t border-[var(--color-line)] pt-8 text-sm text-[var(--color-muted)]">
        <div class="flex items-center justify-between">
          <span>© {new Date().getFullYear()}</span>

        </div>
      </footer>
    </div>
  </body>
</html>
