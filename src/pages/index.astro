---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import Hero from '../components/home/Hero';
import PostList from '../components/home/PostList';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((p) => ({
    slug: p.id,
    title: p.data.title,
    description: p.data.description,
    pubDate: p.data.pubDate,
    tags: p.data.tags,
    image: p.data.image
      ? {
          src: p.data.image.src.src,
          width: p.data.image.src.width,
          height: p.data.image.src.height,
          alt: p.data.image.alt,
        }
      : null,
  }));
---

<BaseLayout
  title="The Attention Span"
  description="בלוג על Machine Learning ו-Deep Learning עם הדגמות אינטראקטיביות. אינטואיציה לפני נוסחאות, בעברית, עם דמואים שרצים בדפדפן."
  theme="dark"
  appendSiteName={false}
>
  <Hero client:load slot="hero" />

  <section slot="wide" class="mt-8">
    <h2 class="mb-8 text-sm font-medium text-[var(--color-muted)]">
      כתיבה
    </h2>
    {posts.length > 0 ? (
      <PostList client:visible posts={posts} />
    ) : (
      <p class="text-[var(--color-muted)]">אין עדיין מאמרים. הוסיפו אחד ב-<code>src/content/blog/</code>.</p>
    )}
  </section>
</BaseLayout>
