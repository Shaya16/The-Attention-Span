---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="your name · interactive ML">
  <section class="mb-20">
    <h1 class="mb-4" style="font-family: var(--font-display); font-size: clamp(3rem, 7vw, 5rem); line-height: 1; letter-spacing: -0.04em;">
      Things I'm <em class="text-[var(--color-accent)]">trying</em> to understand
    </h1>
    <p class="max-w-xl text-lg text-[var(--color-muted)]">
      Interactive explainers on machine learning, deep learning, and the math behind them.
      Built to be tinkered with.
    </p>
  </section>

  <section>
    <h2 class="mb-6 text-sm font-medium uppercase tracking-widest text-[var(--color-muted)]">
      Recent posts
    </h2>
    <ul class="space-y-1">
      {posts.map((post) => (
        <li>
          <a
            href={`/posts/${post.id}/`}
            class="group flex items-baseline gap-4 border-b border-[var(--color-line)] py-5 transition hover:border-[var(--color-accent)]"
          >
            <time
              datetime={post.data.pubDate.toISOString()}
              class="shrink-0 font-mono text-xs text-[var(--color-muted)]"
            >
              {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: '2-digit', year: '2-digit' })}
            </time>
            <span class="flex-1">
              <span class="font-medium transition group-hover:text-[var(--color-accent)]">
                {post.data.title}
              </span>
              <span class="ml-2 text-sm text-[var(--color-muted)]">
                {post.data.description}
              </span>
            </span>
          </a>
        </li>
      ))}
    </ul>
    {posts.length === 0 && (
      <p class="text-[var(--color-muted)]">No posts yet. Write one in <code>src/content/blog/</code>.</p>
    )}
  </section>
</BaseLayout>
